# Configuración del Backend - ERP2
# Copia este archivo como .env y completa los valores

# Puerto del servidor
PORT=3000

# Secret para JWT (en producción usar una cadena larga y segura)
JWT_SECRET=tu_secret_aqui

# Configuración de la base de datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ERP2


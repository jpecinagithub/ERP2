# Configuración del Backend - ERP2
# Copia este archivo como .env y completa los valores

# Puerto del servidor
PORT=3000

# Secret para JWT (en producción usar una cadena larga y segura)
JWT_SECRET=tu_secret_aqui

# Configuración de la base de datos MySQL / TiDB (MySQL-compatible)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ERP2

# TLS/SSL (TiDB normalmente lo requiere)
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true
# Pega aquí el certificado CA si tu proveedor lo entrega (texto PEM)
# DB_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Alternativa: URL de conexión (prioritaria si existe)
# DATABASE_URL="mysql://user:pass@host:4000/ERP2"

# Migraciones (script: npm run migrate)
# DB_SCHEMA_FILE=01-schemaGPT.sql
# DB_SEED_FILE=02-seedGPT.sql
# DB_SKIP_SEED=false
# DB_STRIP_DB_STATEMENTS=true

